# FlexNetOS local GitHub Actions runner configuration template.
# Copy to a private local file when activating a host. Do not commit real tokens.

# Scope: org or repo. Org is preferred after FlexNetOS org runner policy is ready.
RUNNER_SCOPE=org
RUNNER_ORG=FlexNetOS
# Used only when RUNNER_SCOPE=repo.
RUNNER_REPO=weftos

# Install location. Keep runner binaries and _work outside the git checkout.
RUNNER_HOME=$HOME/_work/repos/actions-runner
RUNNER_WORK_DIR=$HOME/_work/actions-runner-work
RUNNER_VERSION=
RUNNER_ARCH=x64

# Label discipline: never use only `self-hosted` in workflows.
RUNNER_NAME=local-gh-rnr-lnx
RUNNER_LABELS=self-hosted,linux,x64,local,flexnetos
RUNNER_GROUP=default

# Safety defaults. Scripts must stay dry-run/read-only unless explicitly changed.
DRY_RUN=1
CONFIRM=0
INSTALL_SERVICE=0
EPHEMERAL=1
REPLACE=0
RUNNER_USER=drdave

# Registration/removal tokens are short-lived and should be fetched live with gh.
# If pasted manually, keep them in the shell only; never commit them.
RUNNER_REGISTRATION_TOKEN=
RUNNER_REMOVAL_TOKEN=

# Optional GitHub App path for future automation. Store real values in Vaultwarden.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
