#!/usr/bin/env bash
# Pre-push hook: guard direct pushes to protected branches and run fast checks.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

REMOTE="$1"
URL="$2"

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master|refs/heads/trunk)
      echo "[pre-push] BLOCKED: direct push to $remote_ref is not allowed. Open a PR via develop." >&2
      exit 1
      ;;
  esac
done

if [ -f "Makefile" ]; then
  echo "[pre-push] Running fast verification (actionlint + markdown + manifests)..."
  make verify.actionlint verify.markdown verify.manifest verify.tools || {
    echo "[pre-push] Fast verification failed. Fix before pushing." >&2
    exit 1
  }
fi

exit 0
