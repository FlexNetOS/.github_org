#!/usr/bin/env bash
# Pre-commit hook: lint edited GitHub Actions workflows and markdown files.
# Non-fatal if the local lint tools are missing.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)
[ -n "$STAGED" ] || exit 0

fail=0

WORKFLOW_FILES=$(printf '%s\n' "$STAGED" | grep -E '^\.github/workflows/.*\.(yml|yaml)$' || true)
if [ -n "$WORKFLOW_FILES" ] && [ -x "tools/bin/actionlint" ]; then
  echo "[pre-commit] Running actionlint on staged workflow files..."
  if ! printf '%s\n' "$WORKFLOW_FILES" | xargs -r tools/bin/actionlint; then
    echo "[pre-commit] actionlint failed. Fix workflow syntax before committing." >&2
    fail=1
  fi
fi

MD_FILES=$(printf '%s\n' "$STAGED" | grep -E '\.md$' || true)
if [ -n "$MD_FILES" ] && [ -f "scripts/verify-markdown.py" ]; then
  echo "[pre-commit] Running markdown lint on staged .md files..."
  if ! python3 scripts/verify-markdown.py .; then
    echo "[pre-commit] markdown lint failed. Fix lint errors before committing." >&2
    fail=1
  fi
fi

POLICY_FILES=$(printf '%s\n' "$STAGED" | grep -E '^\.github/policies/.*\.json$' || true)
if [ -n "$POLICY_FILES" ]; then
  echo "[pre-commit] Validating policy JSON syntax..."
  while IFS= read -r f; do
    if ! python3 -m json.tool "$f" >/dev/null 2>&1; then
      echo "[pre-commit] JSON syntax error in $f" >&2
      fail=1
    fi
  done <<< "$POLICY_FILES"
fi

exit "$fail"
