<40-CHAR-FINGERPRINT>
#
Add
the
SELF-HOSTED
RUNNER's
GPG
key
fingerprint
here,
one
per
line.
#
This
key
is
authorized
—
together
with
the
personal
key(s)
in
.gpg-id
—
#
to
decrypt
the
secrets/store/runner/
subtree
ONLY.
#
#
The
runner
key
MUST
be
a
separate
key
from
the
personal
key.
Never
#
reuse
the
same
key
on
both
boxes.
#
#
Enable
with:
#
PASSWORD_STORE_DIR="$PWD/secrets/store"
pass
init
\
#
$(cat
secrets/.gpg-id)
$(cat
secrets/.gpg-id.runner)
#
#
PLACEHOLDER-NO-RUNNER-KEY-CONFIGURED
<RUNNER-40-CHAR-FINGERPRINT>
