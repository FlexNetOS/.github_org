# GitHub Actions secret injection map for Bitwarden/Vaultwarden.
#
# Copy this file to secrets/github-secrets.tsv, fill in real item names/IDs,
# and keep the copied file private/local unless every referenced value is safe
# to reveal by name. Values are never stored here; only pointers are stored.
#
# Columns are tab-separated:
# scope	target	secret_name	bw_item	bw_field	visibility	repos
#
# scope:
#   repo  target OWNER/REPO
#   env   target OWNER/REPO:ENVIRONMENT
#   org   target ORG
#
# bw_field:
#   password | username | notes | field:<custom-field-name>
#
# visibility/repos apply only to org scope.

scope	target	secret_name	bw_item	bw_field	visibility	repos
# repo	FlexNetOS/example-repo	OPENAI_API_KEY	OpenAI API - production	password		
# env	FlexNetOS/example-repo:production	DEPLOY_TOKEN	Example deploy token	password		
# org	FlexNetOS	DOCKERHUB_TOKEN	DockerHub FlexNetOS	password	selected	example-repo,another-repo
# org	FlexNetOS	SHARED_READONLY_TOKEN	Shared readonly token	field:token	private
# Cross-repo dispatch and release tokens used by the FlexNetOS/meta fleet.
# NOTE: REPO_WRITE_PACKAGES_PAT was renamed to RELEASE_TOKEN to match the workflow
# contract in release.yml / reusable-release.yml / reusable-rust-release.yml.
# If your vault still has REPO_WRITE_PACKAGES_PAT, either rename it or map both.
# org	FlexNetOS	PARENT_REPO_PAT	FlexNetOS cross-repo dispatch PAT	password	private
# org	FlexNetOS	RELEASE_TOKEN	FlexNetOS release dispatch PAT	password	private
# org	FlexNetOS	LABEL_SYNC_TOKEN	FlexNetOS org label sync PAT	password	private
# org	FlexNetOS	CARGO_REGISTRY_TOKEN	crates.io publishing token	password	private
# org	FlexNetOS	HOMEBREW_TAP_TOKEN	Homebrew tap update PAT	password	private
