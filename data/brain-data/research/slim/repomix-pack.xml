<file path="docs/src/layouts/layout.astro">
---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '@fontsource/ibm-plex-serif/400.css';
import '@fontsource/ibm-plex-serif/500.css';
import '@fontsource/ibm-plex-serif/600.css';
import '@fontsource/ibm-plex-serif/700.css';
import '../styles/global.css';

import geistUrl from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url';
import geistMonoUrl from '@fontsource-variable/geist-mono/files/geist-mono-latin-wght-normal.woff2?url';
import plexSerifUrl from '@fontsource/ibm-plex-serif/files/ibm-plex-serif-latin-500-normal.woff2?url';

const props = Astro.props;
const {
  title = 'Slim - Local HTTPS Domains, Tunnels & Dev Environment Toolkit',
  description = 'Slim maps localhost to pretty .test domains with automatic HTTPS, SSL certificates, WebSocket & HMR support, path routing, and public URL tunnels via slim.show. Free, zero-config CLI built with Go for macOS and Linux.',
} = props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href={geistUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistMonoUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={plexSerifUrl} as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="local https, localhost https, local domains, .test domains, ssl localhost, dev environment, localhost tunnel, share localhost, public url, ngrok alternative, local development, reverse proxy, websocket proxy, hmr proxy, path routing, dev toolkit, slim cli, slim.sh, macOS development, linux development" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL('/og-img.png', Astro.site).href} />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:site_name" content="Slim" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-img.png', Astro.site).href} />

    <link rel="icon" href="/favicon.png" type="image/png" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-34BX59VD6M"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-34BX59VD6M');
    </script>
  </head>
  <body>
    <div class="pointer-events-none fixed inset-y-0 left-1/2 -translate-x-1/2 z-[101] w-full max-w-[calc(var(--max-width)+var(--padding-x)*2)] border-x border-border" aria-hidden="true"></div>
    <slot />
  </body>
</html>
</file>

<file path="docs/src/pages/abuse.astro">
---
import SiteHeader from '../components/site-header.astro';
import SiteFooter from '../components/site-footer.astro';
import Layout from '../layouts/layout.astro';
---

<Layout title="Report Abuse — Slim" description="Report abuse or misuse of slim.show tunnels.">
  <SiteHeader />
  <main class="max-w-(--max-width) mx-auto px-(--padding-x) py-16 min-h-[70vh]">
    <div class="max-w-xl mx-auto">
      <h1 class="text-2xl font-bold text-text mb-2">Report Abuse</h1>
      <p class="text-text-secondary text-[15px] leading-relaxed mb-8">
        If you've encountered a <strong>slim.show</strong> tunnel being used for phishing, malware distribution, or any other malicious activity, please report it below. We take abuse seriously and will investigate promptly.
      </p>

      <div class="space-y-6">
        <section>
          <h2 class="text-base font-semibold text-text mb-2">Email</h2>
          <p class="text-text-secondary text-sm leading-relaxed">
            Send abuse reports to <a href="mailto:abuse@slim.sh" class="text-text underline underline-offset-2 hover:text-white">abuse@slim.sh</a> with the following details:
          </p>
          <ul class="mt-3 space-y-1.5 text-sm text-text-secondary list-disc pl-5">
            <li>The full URL (e.g. <code class="text-text-tertiary bg-surface px-1.5 py-0.5 rounded text-xs">https://example.slim.show</code>)</li>
            <li>Description of the abusive content or behavior</li>
            <li>Screenshots if available</li>
            <li>Date and time you encountered it</li>
          </ul>
        </section>

        <section>
          <h2 class="text-base font-semibold text-text mb-2">What we do</h2>
          <ul class="space-y-1.5 text-sm text-text-secondary list-disc pl-5">
            <li>Investigate all reports within 24 hours</li>
            <li>Immediately terminate tunnels confirmed to be abusive</li>
            <li>Ban accounts engaged in malicious activity</li>
            <li>Cooperate with law enforcement when required</li>
          </ul>
        </section>

        <section>
          <h2 class="text-base font-semibold text-text mb-2">What is slim.show?</h2>
          <p class="text-text-secondary text-sm leading-relaxed">
            <strong class="text-text">slim.show</strong> is a tunnel service by <a href="https://slim.sh" class="text-text underline underline-offset-2 hover:text-white">slim</a> that lets developers share their local development servers via temporary public URLs. Each <code class="text-text-tertiary bg-surface px-1.5 py-0.5 rounded text-xs">*.slim.show</code> subdomain is a user-generated tunnel that exists only while the developer's session is active.
          </p>
        </section>
      </div>
    </div>
  </main>
  <SiteFooter />
</Layout>
</file>

