<file path="docs/src/styles/global.css">
@import 'tailwindcss';

@theme {
  --color-bg: #1a1a1a;
  --color-surface: #232323;
  --color-text: hsl(0 0% 100% / 85%);
  --color-text-secondary: hsl(0 0% 100% / 55%);
  --color-text-tertiary: hsl(0 0% 100% / 40%);
  --color-primary: #60a5fa;
  --color-border: hsl(0 0% 100% / 8%);
  --color-code-bg: #111111;
  --color-code-text: #e5e5e5;

  --font-heading: 'IBM Plex Serif', Georgia, 'Times New Roman', serif;
  --font-body: 'Geist Variable', system-ui, -apple-system, sans-serif;
  --font-mono: 'Geist Mono Variable', 'SF Mono', 'Fira Code', monospace;
}

@layer base {
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --max-width: 760px;
    --padding-x: 24px;
  }

  html {
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: smooth;
    scroll-padding-top: 70px;
  }

  body {
    line-height: 1.6;
    font-size: 15px;
  }

  code,
  pre {
    font-family: var(--font-mono);
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  img {
    max-width: 100%;
  }

  main.home section {
    position: relative;
  }

  main.home section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: 1px;
    background: var(--color-border);
  }

  main.home section#install::before {
    display: none;
  }
}
</file>

