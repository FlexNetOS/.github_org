  "sandbox": {
    "enabled": false,
    "failIfUnavailable": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "*"
      ],
      "allowAllUnixSockets": true
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "~/.cache",
        "~/.npm",
        "~/.bun",
        "~/.cargo",
        "~/.rustup",
        "~/.local",
        "~/.config",
        "~/.claude",
        "~/.kube",
        "~/.docker",
        "~/repos",
        "~/work",
        "~/personal",
        "~/containers"
      ],
      "denyWrite": [
        "~/.bashrc",
        "~/.profile",
        "~/.bash_profile",
        "~/.bash_history",
        "~/.ssh",
        "~/.gnupg",
        "~/.aws"
      ]
    },
    "excludedCommands": [
      "docker *",
      "docker compose *",
      "virsh *",
      "virt-manager *",
      "qemu-system-* *",
      "ssh *",
      "scp *",
      "sftp *",
      "rsync *"
    ]
  },
  "advisorModel": "claude-opus-4-7",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "omcHud": {
    "preset": "full",
    "elements": {
      "omcLabel": true,
      "ralph": true,
      "autopilot": true,
      "prdStory": true,
      "activeSkills": true,
      "lastSkill": true,
      "contextBar": true,
      "agents": true,
      "agentsFormat": "multiline",
      "backgroundTasks": true,
      "todos": true,
      "thinking": true,
      "thinkingFormat": "text",
      "permissionStatus": true,
      "apiKeySource": true,
      "profile": true,
      "promptTime": true,
      "sessionHealth": true,
      "useBars": true,
      "showCallCounts": true,
      "callCountsFormat": "auto",
      "safeMode": true,
      "maxOutputLines": 8
    },
    "thresholds": {
      "contextWarning": 70,
      "contextCompactSuggestion": 80,
      "contextCritical": 85,
      "ralphWarning": 7
    },
    "staleTaskThresholdMinutes": 30,
    "contextLimitWarning": {
      "threshold": 80,
      "autoCompact": false
    }
  }
}