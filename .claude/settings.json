{
  "permissions": {
    "allow": [
      "mcp__open-pencil",
      "Bash(./launch.sh)",
      "Bash(./launch.sh:*)",
      "Bash(*codeagent-wrapper*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/actionlint-on-workflow-edit.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/icm-architecture-inject.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude --ultra-compact"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/protect-secrets-store.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/gitmodules-drift-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/icm-architecture-inject.sh",
            "timeout": 12000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "ecc@ecc": true,
    "example-mcp@claude-stack-local": true,
    "github@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "playwright@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ui5-typescript-conversion@claude-plugins-official": true,
    "understand-anything@understand-anything": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-stack-local": {
      "source": {
        "source": "directory",
        "path": "${META_ROOT}/_work/claude-stack/plugins"
      }
    },
    "ecc": {
      "source": {
        "source": "file",
        "path": "${META_ROOT}/_work/repos/everything-claude-code/.claude-plugin/marketplace.json"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "file",
        "path": "${META_ROOT}/_work/repos/andrej-karpathy-skills/.claude-plugin/marketplace.json"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git",
        "path": "${META_ROOT}/repos/oh-my-claudecode/.claude-plugin/marketplace.json"
      }
    },
    "understand-anything": {
      "source": {
        "source": "file",
        "path": "${META_ROOT}/_work/repos/Understand-Anything/.claude-plugin/marketplace.json"
      }
    }
  }
}
