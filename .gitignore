# =============================================================================
# FlexNetOS/.github  —  .gitignore
# =============================================================================
# Submodules under repos/ each carry their own .gitignore. The patterns
# below are defense-in-depth: things that should never be tracked here
# even if something escapes a submodule boundary.

# --- Local workspace artifacts (oh-my-claudecode + agent harnesses) ---
# .claude/ config, hooks, settings, and skills ARE tracked. The plugin cache
# and marketplace downloads are NOT — they are regenerated by `omc install`
# and can be hundreds of MB. .omc/ state is tracked. .omp/ and .attic/ ignored.
.omp/
.attic/
# Plugin cache — downloaded content, regenerable, never commit (can be 500MB+)
.claude/plugins/cache/
.claude/plugins/marketplaces/
.claude/plugins/data/
# ruflo / claude-flow runtime SQLite database — transient, regenerated on demand.
ruvector.db
ruvector.db-shm
ruvector.db-wal

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# --- Local lint / cache directories ---
.cache/
tools/.cache/
node_modules/
.markdownlint-cli2.cache/

# --- Language / tooling generated artifacts (defense in depth) ---
# Rust
target/
# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/
*.egg-info/
# Node / JS frameworks
.next/
.nuxt/
out/
.turbo/
.parcel-cache/
# Go
vendor/
# Tauri
src-tauri/target/

# --- Secrets safety (defense in depth) ---
# secrets/store/ holds pass GPG blobs and IS tracked; cleartext escapes are not.
.env
.env.*
!.env*.tmpl
!.env*.example
*.pem
*.key
!secrets/.gpg-id*
secrets/decrypted/
secrets/scratch/
# Local Bitwarden/Vaultwarden → GitHub mapping may reveal secret names/topology.
secrets/github-secrets.tsv
!secrets/github-secrets.tsv.example

# --- Wiki: Obsidian local state, ingest scratch ---
wiki/.obsidian/
wiki/raw/.scratch/

# --- Self-hosted runner state — config/scripts are tracked, runtime state is not ---
runner/_diag/
runner/_work/
runner/.runner
runner/.credentials*

# --- Local nested repos pending canonical submodule mount ---
# LifeOS is a separate product repo; keep a local checkout from being committed
# into this control-plane repo as plain files before its remote/path are chosen.
lifeos/

# --- Tool/upstream clones pending fork decision ---
# Rule: any upstream cloned for umbrella use (whether destined for repos/ as a
# research target, or for tools/ as vendored plumbing) stays gitignored until
# the umbrella commits to forking it. Once forked, the directory is removed
# from this list and registered in the corresponding MANIFEST.yaml + .gitmodules.
# See data/brain-data/research/repomix.md and docs/fork-workflow.md Step 0.
tools/repomix/

# --- ai-top reference materials live in the sibling workspace, never here ---
ai-top/

# OpenSpec init AI-tooling under architecture/ (local only; fails markdown lint, not committed)
architecture/.claude/
